<Window x:Class="SerialPortDebugger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Height="640" Width="1020"
        MinHeight="520" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif"
        TextElement.Foreground="#D0D0D8"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ============ 颜色常量 ============ -->
        <SolidColorBrush x:Key="BgPrimary" Color="#1E1E24"/>
        <SolidColorBrush x:Key="BgSurface" Color="#282832"/>
        <SolidColorBrush x:Key="BgInput" Color="#333340"/>
        <SolidColorBrush x:Key="BgTitleBar" Color="#1A1A22"/>
        <SolidColorBrush x:Key="BorderColor" Color="#404050"/>
        <SolidColorBrush x:Key="BorderFocus" Color="#5B8DEF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#D0D0D8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9090A0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#686878"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#5B8DEF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#7BAAFF"/>
        <SolidColorBrush x:Key="AccentPressed" Color="#3D6FD4"/>
        <SolidColorBrush x:Key="Green" Color="#4ECB71"/>
        <SolidColorBrush x:Key="Red" Color="#F4475B"/>
        <SolidColorBrush x:Key="Orange" Color="#F0A040"/>
        <SolidColorBrush x:Key="TerminalBg" Color="#16161C"/>
        <SolidColorBrush x:Key="TerminalFg" Color="#B0B8C8"/>

        <!-- ============ ScrollBar Thumb Style ============ -->
        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#555568" CornerRadius="3"
                                Width="6" Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ ScrollBar Style ============ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent" CornerRadius="3">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============ TitleBar Window Buttons ============ -->
        <Style x:Key="WinButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#3A3A4C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#2A2A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinButton}">
            <Setter Property="Foreground" Value="#D0D0D8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#BF0F1D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============ Button Style ============ -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A4C"/>
            <Setter Property="Foreground" Value="#D0D0D8"/>
            <Setter Property="BorderBrush" Value="#4A4A5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A4A5E"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5B8DEF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="#5B8DEF"/>
            <Setter Property="BorderBrush" Value="#5B8DEF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7BAAFF"/>
                    <Setter Property="BorderBrush" Value="#7BAAFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3D6FD4"/>
                    <Setter Property="BorderBrush" Value="#3D6FD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============ ComboBox Style ============ -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3A3A4C"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#555570"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 底层：下拉按钮 -->
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                x:Name="border">
                                            <Path Data="M0,0 L4,4 L8,0"
                                                  Stroke="#B0B0C0" StrokeThickness="1.5"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Fill="Transparent"
                                                  Margin="0,0,9,0"
                                                  x:Name="arrow"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#5B8DEF"/>
                                                <Setter TargetName="arrow" Property="Stroke" Value="#5B8DEF"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#5B8DEF"/>
                                                <Setter TargetName="arrow" Property="Stroke" Value="#5B8DEF"/>
                                                <Setter TargetName="arrow" Property="Data"
                                                        Value="M0,4 L4,0 L8,4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- 上层：显示选中内容 / 可编辑文本框 -->
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="6,2,22,2"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              TextElement.Foreground="#FFFFFF"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="6,1,18,1"
                                     VerticalAlignment="Center"
                                     Visibility="Hidden"
                                     Background="Transparent"
                                     Foreground="#FFFFFF"
                                     CaretBrush="#FFFFFF"
                                     BorderThickness="0"
                                     FontSize="12"
                                     Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <!-- 下拉面板 -->
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   Placement="Bottom">
                                <Grid>
                                    <Border Background="#18182A"
                                            BorderBrush="#6B8DEF"
                                            BorderThickness="1.5"
                                            CornerRadius="4"
                                            Margin="0,2,0,0"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Padding="4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="10"
                                                              ShadowDepth="2" Opacity="0.8"/>
                                        </Border.Effect>
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="False">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#E8E8F0"/>
                        <Setter Property="Padding" Value="8,7"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="3"
                                            Margin="0,1"
                                            x:Name="border">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#8888B0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#9090CC"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#6B7FEF"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ TextBox Style ============ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#333340"/>
            <Setter Property="Foreground" Value="#D0D0D8"/>
            <Setter Property="BorderBrush" Value="#404050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#D0D0D8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                x:Name="border">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5B8DEF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5B8DEF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ CheckBox Style ============ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#B0B0C0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="18" Height="18"
                                    Background="#333340"
                                    BorderBrush="#505060"
                                    BorderThickness="1.5"
                                    CornerRadius="3"
                                    x:Name="checkBorder"
                                    Margin="0,0,6,0"
                                    SnapsToDevicePixels="True">
                                <Path x:Name="checkMark"
                                      Data="M3,8 L7,12 L14,5"
                                      Stroke="#5B8DEF"
                                      StrokeThickness="2"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#5B8DEF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#5B8DEF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Card Header Style ============ -->
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C8C8D8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

    </Window.Resources>

    <!-- ============ 主容器（带圆角 + 边框） ============ -->
    <Border Background="#1E1E24"
            BorderBrush="#2A2A38" BorderThickness="1"
            CornerRadius="8"
            x:Name="WindowBorder">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 自定义标题栏 ===== -->
            <Border Grid.Row="0" Background="#1A1A22"
                    BorderBrush="#2A2A38" BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Height="38"
                    x:Name="TitleBar"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：软件标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="🔌" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="串口调试器"
                                   Foreground="#D0D0D8"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="· SerialPort Debugger"
                                   Foreground="#686878"
                                   FontSize="12"
                                   VerticalAlignment="Center" Margin="4,1,0,0"/>
                    </StackPanel>

                    <!-- 右侧：窗口操作按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Style="{StaticResource WinButton}"
                                Background="Transparent"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Content="─" FontSize="12"
                                Click="BtnMinimize_Click"
                                ToolTip="最小化"/>
                        <Button x:Name="BtnMaximize"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource WinButton}"
                                Content="□" FontSize="12"
                                Click="BtnMaximize_Click"
                                ToolTip="最大化"/>
                        <Button Style="{StaticResource CloseButton}"
                                Content="✕" FontSize="14"
                                Click="BtnClose_Click"
                                ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 主内容区域 ===== -->
            <Grid Grid.Row="1" Margin="16,12,16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="80"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="80"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="40"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 串口设置卡片 -->
                <Border Grid.Row="0" Background="#282832"
                        BorderBrush="#363648" BorderThickness="1"
                        CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="串口设置"
                                   Style="{StaticResource CardHeader}"/>
                        <DockPanel Grid.Row="1" VerticalAlignment="Center">
                            <!-- 打开/关闭按钮（始终可用，不在 IsConfigEnabled 范围内） -->
                            <Button Content="{Binding OpenCloseButtonText}"
                                    Width="90" Height="30"
                                    Margin="4,0,0,0" FontWeight="SemiBold" FontSize="12"
                                    VerticalAlignment="Center"
                                    Command="{Binding OpenCloseCommand}"
                                    DockPanel.Dock="Right">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPortOpen}" Value="True">
                                                <Setter Property="Background" Value="#D94050"/>
                                                <Setter Property="BorderBrush" Value="#D94050"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPortOpen}" Value="False">
                                                <Setter Property="Background" Value="#4ECB71"/>
                                                <Setter Property="BorderBrush" Value="#4ECB71"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <!-- 配置控件（端口打开时禁用） -->
                            <WrapPanel IsEnabled="{Binding IsConfigEnabled}"
                                       VerticalAlignment="Center">
                            <!-- 串口号 -->
                            <Border Background="#333340" CornerRadius="4"
                                    Padding="6,4" Margin="0,0,6,4"
                                    BorderBrush="#404050" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="串口" Foreground="#9090A0"
                                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                    <ComboBox Width="100"
                                              ItemsSource="{Binding AvailablePorts}"
                                              SelectedItem="{Binding SelectedPortName}"
                                              IsEditable="True"
                                              BorderThickness="0" Background="Transparent"
                                              MinHeight="24"/>
                                </StackPanel>
                            </Border>
                            <Button Content="⟳" Width="30" Height="30"
                                    Style="{StaticResource FlatButton}"
                                    Command="{Binding RefreshPortsCommand}"
                                    ToolTip="刷新串口列表"
                                    Margin="0,0,8,4"
                                    FontSize="13" Padding="0"/>
                            <!-- 波特率 -->
                            <Border Background="#333340" CornerRadius="4"
                                    Padding="6,4" Margin="0,0,6,4"
                                    BorderBrush="#404050" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="波特率" Foreground="#9090A0"
                                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                    <ComboBox Width="110"
                                              ItemsSource="{Binding BaudRates}"
                                              SelectedItem="{Binding SelectedBaudRate}"
                                              IsEditable="True"
                                              BorderThickness="0" Background="Transparent"
                                              MinHeight="24"/>
                                </StackPanel>
                            </Border>
                            <!-- 数据位 -->
                            <Border Background="#333340" CornerRadius="4"
                                    Padding="6,4" Margin="0,0,6,4"
                                    BorderBrush="#404050" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="数据位" Foreground="#9090A0"
                                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                    <ComboBox Width="50"
                                              ItemsSource="{Binding DataBitsOptions}"
                                              SelectedItem="{Binding SelectedDataBits}"
                                              BorderThickness="0" Background="Transparent"
                                              MinHeight="24"/>
                                </StackPanel>
                            </Border>
                            <!-- 校验位 -->
                            <Border Background="#333340" CornerRadius="4"
                                    Padding="6,4" Margin="0,0,6,4"
                                    BorderBrush="#404050" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="校验" Foreground="#9090A0"
                                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                    <ComboBox Width="86"
                                              ItemsSource="{Binding ParityOptions}"
                                              SelectedItem="{Binding SelectedParity}"
                                              BorderThickness="0" Background="Transparent"
                                              MinHeight="24"/>
                                </StackPanel>
                            </Border>
                            <!-- 停止位 -->
                            <Border Background="#333340" CornerRadius="4"
                                    Padding="6,4" Margin="0,0,6,4"
                                    BorderBrush="#404050" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="停止位" Foreground="#9090A0"
                                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                    <ComboBox Width="56"
                                              ItemsSource="{Binding StopBitsOptions}"
                                              SelectedItem="{Binding SelectedStopBits}"
                                              BorderThickness="0" Background="Transparent"
                                              MinHeight="24"/>
                                </StackPanel>
                            </Border>
                            <!-- 流控 -->
                            <Border Background="#333340" CornerRadius="4"
                                    Padding="6,4" Margin="0,0,6,4"
                                    BorderBrush="#404050" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="流控" Foreground="#9090A0"
                                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                    <ComboBox Width="88"
                                              ItemsSource="{Binding FlowControlOptions}"
                                              SelectedItem="{Binding SelectedFlowControl}"
                                              BorderThickness="0" Background="Transparent"
                                              MinHeight="24"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <!-- 接收区域卡片 -->
                <Border Grid.Row="1" Background="#282832"
                        BorderBrush="#363648" BorderThickness="1"
                        CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="接收数据"
                                       Style="{StaticResource CardHeader}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding RxCountText}"
                                           Foreground="#686878" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <CheckBox Content="HEX" IsChecked="{Binding IsHexDisplay}"
                                          Margin="0,0,8,0"/>
                                <CheckBox Content="自动滚动" IsChecked="{Binding IsAutoScroll}"
                                          Margin="0,0,8,0"
                                          x:Name="chkAutoScroll"/>
                                <Button Content="清空" Width="52" Height="26"
                                        Style="{StaticResource FlatButton}"
                                        Command="{Binding ClearReceiveCommand}"
                                        FontSize="11" Padding="4,2"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="#16161C"
                                BorderBrush="#2A2A36" BorderThickness="1"
                                CornerRadius="4">
                            <TextBox Text="{Binding ReceivedText, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Visible"
                                     IsReadOnly="True"
                                     FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="13"
                                     Background="Transparent"
                                     Foreground="#B0B8C8"
                                     BorderThickness="0"
                                     x:Name="txtReceive"
                                     Padding="10,8"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 分隔条 -->
                <GridSplitter Grid.Row="2" Height="3" HorizontalAlignment="Stretch"
                              Background="#2A2A38" Cursor="SizeNS"
                              ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

                <!-- 发送区域卡片 -->
                <Border Grid.Row="3" Background="#282832"
                        BorderBrush="#363648" BorderThickness="1"
                        CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="发送数据"
                                       Style="{StaticResource CardHeader}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding TxCountText}"
                                           Foreground="#686878" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <CheckBox Content="HEX" IsChecked="{Binding IsHexSend}"
                                          Margin="0,0,8,0"/>
                                <CheckBox Content="追加换行" IsChecked="{Binding IsSendNewLine}"
                                          Margin="0,0,8,0"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="#16161C"
                                BorderBrush="#2A2A36" BorderThickness="1"
                                CornerRadius="4">
                            <TextBox Text="{Binding SendText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Visible"
                                     FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="13"
                                     Background="Transparent"
                                     Foreground="#B0B8C8"
                                     BorderThickness="0"
                                     AcceptsReturn="True"
                                     Padding="10,8"/>
                        </Border>
                        <WrapPanel Grid.Row="2" Margin="0,10,0,0"
                                   VerticalAlignment="Center">
                            <TextBlock Text="定时发送" Foreground="#9090A0"
                                       VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                            <TextBox Text="{Binding AutoSendInterval, UpdateSourceTrigger=PropertyChanged}"
                                     Width="64" Margin="0,0,4,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="ms" Foreground="#686878"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="10"/>
                            <CheckBox Content="启用" IsChecked="{Binding IsAutoSend}"
                                      VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Button Content="▶ 发送" Width="80" Height="34"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding SendCommand}"
                                    FontSize="13" FontWeight="SemiBold"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <!-- 分隔条 -->
                <GridSplitter Grid.Row="4" Height="3" HorizontalAlignment="Stretch"
                              Background="#2A2A38" Cursor="SizeNS"
                              ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

                <!-- 运行日志面板 -->
                <Border Grid.Row="5" Background="#1A1A22"
                        BorderBrush="#2A2A38" BorderThickness="0,1,0,0"
                        Padding="10,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="运行日志"
                                   Foreground="#686878" FontSize="10"
                                   Margin="0,2,0,4"/>
                        <TextBox Grid.Row="1"
                                 Text="{Binding LogText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Foreground="#787888"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="11"
                                 BorderThickness="0"
                                 MaxHeight="80"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 x:Name="txtLog"
                                 Padding="0"/>
                    </Grid>
                </Border>

                <!-- 状态栏 -->
                <Border Grid.Row="6" Background="#1A1A24"
                        BorderBrush="#2A2A38" BorderThickness="0,1,0,0"
                        CornerRadius="0,0,6,6"
                        Padding="12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding PortStateColor}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#808090" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PortStateText}"
                                   Foreground="{Binding PortStateColor}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
